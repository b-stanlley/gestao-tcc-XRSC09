# Copie este arquivo para ".env" (na raiz do projeto) e preencha.
# O .env NAO vai para o Git (esta no .gitignore). O backend Python carrega este .env automaticamente.

# --- Banco de dados (MySQL) ---
# Sem estas variaveis / sem o servidor MySQL, o sistema roda em fallback de memoria.
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=sua_senha_do_mysql
DB_NAME=tcc_db

# --- Provedor de LLM (Servico de IA) ---
# "simulado" (offline, padrao) | "gemini" (API do Google) | "http" (stub local) | "ollama"
LLM_PROVIDER=simulado
# Para usar o Gemini: defina LLM_PROVIDER=gemini e a chave abaixo
# (gere a chave em https://aistudio.google.com/apikey).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
